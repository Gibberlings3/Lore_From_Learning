IF
  Global("cd_lore_class_%index%","LOCALS",0)
  !Class(Player1,%index%)
  OR(5)    
    Class(Player2,%index%)
    Class(Player3,%index%)
    Class(Player4,%index%)
    Class(Player5,%index%)
    Class(Player6,%index%)
THEN
  RESPONSE #100
    SetGlobal("cd_lore_class_%index%","LOCALS",1)
    IncrementGlobal("cd_lore_class_total","LOCALS",1)
END 